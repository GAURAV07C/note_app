    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "start-server-and-test dev http://localhost:3000 jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
